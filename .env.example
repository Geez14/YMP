# =========================
# Required for app runtime
# =========================

# Required: Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Required: Supabase anon key (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required: Supabase service role key (server-only, keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required: Postgres connection string (Supabase pooler/direct URL)
DATABASE_URL=postgresql://postgres.your-project-ref:[PASSWORD]@aws-1-region.pooler.supabase.com:5432/postgres

# Required: hashing algorithm used for song deduplication
# Recommended: sha256
SONG_HASH_ALGORITHM=sha256


# =========================
# Optional configuration
# =========================

# Optional: display name used in UI/header
NEXT_PUBLIC_APP_NAME=YMP

# Optional: storage bucket override (defaults to "music")
NEXT_PUBLIC_MUSIC_BUCKET=music

# Optional: client-side upload compression target bitrate (defaults to "128k")
NEXT_PUBLIC_UPLOAD_BITRATE=128k
